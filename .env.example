# ═══════════════════════════════════════════════════════
#  Central de Tarefas — exemplo de variáveis de ambiente
#  Copie para .env.local e preencha com seus valores.
# ═══════════════════════════════════════════════════════

# ── Servidor / backend only ─────────────────────────────
# Nunca exponha estes valores ao navegador.
SUPABASE_URL=http://SEU_IP:54321
SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
FRONTEND_URL=http://localhost:8080
PORT=8088
NODE_ENV=production
MANUAL_INVITE_TEMP_PASSWORD=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
GITHUB_TOKEN=seu_github_pat
NATIVE_ADMIN_EMAILS=usuario1@empresa.com,usuario2@empresa.com
CENTRAL_SSO_ENABLED=false
CENTRAL_SSO_ALLOW_LEGACY_PASSWORD_LOGIN=true
CENTRAL_SSO_PORTAL_URL=https://auth.seudominio.com
CENTRAL_SSO_CLIENT_ID=cdt-web
CENTRAL_SSO_CLIENT_SECRET=
CENTRAL_SSO_AUTHORIZE_PATH=/authorize
CENTRAL_SSO_TOKEN_PATH=/token
CENTRAL_SSO_LOGOUT_PATH=/logout
CENTRAL_SSO_REDIRECT_URI=http://localhost:3003/auth/callback
CENTRAL_SSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3003/login
CENTRAL_SSO_SCOPE=openid profile email
CENTRAL_SSO_STATE_SECRET=troque-por-um-segredo-forte
CENTRAL_SSO_STATE_TTL_SECONDS=300

# ── Frontend build-time public config ───────────────────
# Tudo que começa com VITE_* entra no bundle do navegador.
VITE_SUPABASE_URL=http://SEU_IP:54321
VITE_SUPABASE_ANON_KEY=sua_anon_key
VITE_API_URL=

# ── Frontend dev server / proxy tuning ──────────────────
# Usado apenas no fluxo de desenvolvimento local ou em LAN controlada.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3002
BACKEND_DEV_URL=
VITE_API_PROXY_TARGET=
VITE_PORT=3003
VITE_HOST=localhost
VITE_HMR_HOST=
VITE_HMR_PROTOCOL=
VITE_HMR_CLIENT_PORT=
